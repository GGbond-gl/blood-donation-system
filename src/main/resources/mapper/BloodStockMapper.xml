<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sdut.blood.mapper.BloodStockMapper">

    <resultMap id="BaseResultMap" type="com.sdut.blood.domain.entity.BloodStock">
        <id column="id" property="id"/>
        <result column="collection_id" property="collectionId"/>
        <result column="blood_type" property="bloodType"/>
        <result column="blood_amount" property="bloodAmount"/>
        <result column="expire_date" property="expireDate"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, collection_id, blood_type, blood_amount, expire_date, status,
        create_time, update_time, deleted
    </sql>

    <!-- 按血型统计库存总量 -->
    <select id="selectStockTotalByBloodType" resultType="map">
        SELECT
            blood_type,
            SUM(blood_amount) AS total_amount,
            COUNT(*) AS record_count
        FROM blood_stock
        WHERE blood_type = #{bloodType}
          AND status = '正常'
          AND deleted = 0
        GROUP BY blood_type
    </select>

    <!-- 查询临期库存 -->
    <select id="selectNearExpireList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM blood_stock
        WHERE DATEDIFF(expire_date, CURDATE()) &lt;= #{days}
        AND status = '正常'
        AND deleted = 0
        ORDER BY expire_date ASC
    </select>

</mapper>